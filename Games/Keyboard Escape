return function(hub)
    local Players = game:GetService("Players")
    local ReplicatedStorage = game:GetService("ReplicatedStorage")
    local UserInputService = game:GetService("UserInputService")
    local RunService = game:GetService("RunService")
    local LocalPlayer = Players.LocalPlayer
    
    local state = {
        AutoClick = false,
        AutoCollect = false,
        AutoUpgrade = false
    }
    
    local function notify(text)
        hub:Notify("Keyboard Tycoon", text, 3)
    end
    
    local function getRoot()
        local char = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
        return char:WaitForChild("HumanoidRootPart")
    end
    
    local remotes = ReplicatedStorage:FindFirstChild("Remotes")
    if not remotes then
        remotes = ReplicatedStorage:WaitForChild("RemoteEvents")
    end
    
    local clickRemote = remotes:FindFirstChild("Click") or remotes:FindFirstChild("Collect")
    local collectRemote = remotes:FindFirstChild("CollectCash") or remotes:FindFirstChild("Collect")
    local upgradeRemote = remotes:FindFirstChild("Upgrade") or remotes:FindFirstChild("BuyUpgrade")
    
    local mainTab = hub:Tab("Main", "⌨️")
    local farmTab = hub:Tab("Auto Farm", "⚡")
    local miscTab = hub:Tab("Misc", "🔗")
    
    mainTab:Section("Keyboard Controls")
    
    mainTab:Button("Click", function()
        if clickRemote then
            clickRemote:FireServer()
            notify("Clicked!")
        else
            notify("Click remote not found!")
        end
    end)
    
    mainTab:Toggle(
        "Auto Click [ON]",
        "Auto Click [OFF]",
        function()
            state.AutoClick = true
            task.spawn(function()
                while state.AutoClick do
                    if clickRemote then
                        clickRemote:FireServer()
                    end
                    task.wait(0.05)
                end
            end)
            notify("Auto click started!")
            return true
        end,
        function()
            state.AutoClick = false
            notify("Auto click stopped.")
        end
    )
    
    mainTab:Divider()
    
    mainTab:Button("Collect Cash", function()
        if collectRemote then
            collectRemote:FireServer()
            notify("Collected!")
        else
            notify("Collect remote not found!")
        end
    end)
    
    mainTab:Toggle(
        "Auto Collect [ON]",
        "Auto Collect [OFF]",
        function()
            state.AutoCollect = true
            task.spawn(function()
                while state.AutoCollect do
                    if collectRemote then
                        collectRemote:FireServer()
                    end
                    task.wait(2)
                end
            end)
            notify("Auto collect started!")
            return true
        end,
        function()
            state.AutoCollect = false
            notify("Auto collect stopped.")
        end
    )
    
    farmTab:Section("Upgrade Controls")
    
    farmTab:Button("Upgrade", function()
        if upgradeRemote then
            upgradeRemote:FireServer()
            notify("Upgraded!")
        else
            notify("Upgrade remote not found!")
        end
    end)
    
    farmTab:Toggle(
        "Auto Upgrade [ON]",
        "Auto Upgrade [OFF]",
        function()
            state.AutoUpgrade = true
            task.spawn(function()
                while state.AutoUpgrade do
                    if upgradeRemote then
                        upgradeRemote:FireServer()
                    end
                    task.wait(2)
                end
            end)
            notify("Auto upgrade started!")
            return true
        end,
        function()
            state.AutoUpgrade = false
            notify("Auto upgrade stopped.")
        end
    )
    
    farmTab:Divider()
    
    local clickSpeed = farmTab:Slider("Click Speed (ms)", {50, 100, 150, 200, 250, 300, 400, 500, 750, 1000}, 1)
    
    farmTab:Button("Apply Click Speed", function()
        local speed = clickSpeed()
        notify("Click speed set to " .. tostring(speed) .. "ms")
    end)
    
    miscTab:Section("Links")
    miscTab:Button("Copy Discord Invite", function()
        hub:Copy("https://discord.gg/nQr2ZFE6Ae")
        notify("Discord link copied!")
    end)
    
    miscTab:Section("Info")
    miscTab:Label("Keyboard Tycoon v1.0", Color3.fromRGB(150, 150, 150))
    miscTab:Label("AquaScripts Hub", Color3.fromRGB(100, 180, 255))
    
    task.wait(1)
    notify("Keyboard Tycoon loaded successfully!", 3)
end
