return function(hub)
    --[[
        AquaScriptsYT - Keyboard Escape
        Universal Script with Auto Rebirth, Farm Last Zone, Fly, Noclip & More
    ]]

    local Players = game:GetService("Players")
    local UserInputService = game:GetService("UserInputService")
    local RunService = game:GetService("RunService")
    local ReplicatedStorage = game:GetService("ReplicatedStorage")
    local VirtualUser = game:GetService("VirtualUser")
    local TweenService = game:GetService("TweenService")
    local LocalPlayer = Players.LocalPlayer

    local playerState = {
        Flying = false,
        FlySpeed = 50,
        UsePlatformStand = true,
        Noclip = false,
        AntiAFK = true,
        Frozen = false,
        AutoWalking = false,
        AutoRebirth = false,
        FarmLastZone = false
    }

    local keybinds = {
        Forward = Enum.KeyCode.W,
        Backward = Enum.KeyCode.S,
        Left = Enum.KeyCode.A,
        Right = Enum.KeyCode.D,
        Up = Enum.KeyCode.Space,
        Down = Enum.KeyCode.LeftShift,
        Speed2x = Enum.KeyCode.LeftControl,
        Speed4x = Enum.KeyCode.LeftAlt
    }

    -- ============================================
    -- Popup System (Full Screen Center with Blur)
    -- ============================================

    local function createPopup(title, message, acceptText, declineText, onAccept, onDecline)
        local playerGui = LocalPlayer:WaitForChild("PlayerGui")

        local popupGui = Instance.new("ScreenGui")
        popupGui.Name = "PopupGui"
        popupGui.ResetOnSpawn = false
        popupGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
        popupGui.DisplayOrder = 999
        popupGui.Parent = playerGui

        local blur = Instance.new("BlurEffect")
        blur.Name = "PopupBlur"
        blur.Size = 0
        blur.Parent = game:GetService("Lighting")

        TweenService:Create(blur, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
            Size = 20
        }):Play()

        local overlay = Instance.new("Frame")
        overlay.Name = "PopupOverlay"
        overlay.Size = UDim2.new(1, 0, 1, 0)
        overlay.Position = UDim2.new(0, 0, 0, 0)
        overlay.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
        overlay.BackgroundTransparency = 0.6
        overlay.BorderSizePixel = 0
        overlay.ZIndex = 1
        overlay.Parent = popupGui

        local popup = Instance.new("Frame")
        popup.Name = "PopupFrame"
        popup.Size = UDim2.fromOffset(400, 220)
        popup.Position = UDim2.new(0.5, -200, 0.5, -110)
        popup.BackgroundColor3 = Color3.fromRGB(25, 25, 30)
        popup.BorderSizePixel = 0
        popup.ClipsDescendants = false
        popup.ZIndex = 2
        popup.Parent = overlay

        local corner = Instance.new("UICorner")
        corner.CornerRadius = UDim.new(0, 12)
        corner.Parent = popup

        local stroke = Instance.new("UIStroke")
        stroke.Color = Color3.fromRGB(255, 200, 50)
        stroke.Thickness = 2
        stroke.Parent = popup

        local titleLabel = Instance.new("TextLabel")
        titleLabel.Size = UDim2.new(1, -30, 0, 40)
        titleLabel.Position = UDim2.new(0, 15, 0, 15)
        titleLabel.BackgroundTransparency = 1
        titleLabel.Text = title or "⚠️ Warning"
        titleLabel.TextColor3 = Color3.fromRGB(255, 200, 50)
        titleLabel.Font = Enum.Font.GothamBold
        titleLabel.TextSize = 22
        titleLabel.TextXAlignment = Enum.TextXAlignment.Left
        titleLabel.ZIndex = 3
        titleLabel.Parent = popup

        local messageLabel = Instance.new("TextLabel")
        messageLabel.Size = UDim2.new(1, -30, 0, 50)
        messageLabel.Position = UDim2.new(0, 15, 0, 60)
        messageLabel.BackgroundTransparency = 1
        messageLabel.Text = message or "This action may cause you to get kicked from the game. Proceed with caution."
        messageLabel.TextColor3 = Color3.fromRGB(200, 200, 210)
        messageLabel.Font = Enum.Font.Gotham
        messageLabel.TextSize = 14
        messageLabel.TextWrapped = true
        messageLabel.TextXAlignment = Enum.TextXAlignment.Left
        messageLabel.ZIndex = 3
        messageLabel.Parent = popup

        local icon = Instance.new("TextLabel")
        icon.Size = UDim2.fromOffset(40, 40)
        icon.Position = UDim2.new(1, -55, 0, 15)
        icon.BackgroundTransparency = 1
        icon.Text = "⚠️"
        icon.TextSize = 30
        icon.ZIndex = 3
        icon.Parent = popup

        local btnContainer = Instance.new("Frame")
        btnContainer.Size = UDim2.new(1, -30, 0, 44)
        btnContainer.Position = UDim2.new(0, 15, 1, -54)
        btnContainer.BackgroundTransparency = 1
        btnContainer.ZIndex = 3
        btnContainer.Parent = popup

        local declineBtn = Instance.new("TextButton")
        declineBtn.Size = UDim2.new(0.45, -5, 1, 0)
        declineBtn.Position = UDim2.new(0, 0, 0, 0)
        declineBtn.BackgroundColor3 = Color3.fromRGB(60, 60, 70)
        declineBtn.Text = declineText or "❌ Decline"
        declineBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
        declineBtn.Font = Enum.Font.GothamBold
        declineBtn.TextSize = 15
        declineBtn.ZIndex = 4
        declineBtn.Parent = btnContainer

        local declineCorner = Instance.new("UICorner")
        declineCorner.CornerRadius = UDim.new(0, 8)
        declineCorner.Parent = declineBtn

        declineBtn.MouseEnter:Connect(function()
            declineBtn.BackgroundColor3 = Color3.fromRGB(80, 80, 90)
        end)
        declineBtn.MouseLeave:Connect(function()
            declineBtn.BackgroundColor3 = Color3.fromRGB(60, 60, 70)
        end)

        local acceptBtn = Instance.new("TextButton")
        acceptBtn.Size = UDim2.new(0.45, -5, 1, 0)
        acceptBtn.Position = UDim2.new(0.55, 5, 0, 0)
        acceptBtn.BackgroundColor3 = Color3.fromRGB(255, 200, 50)
        acceptBtn.Text = acceptText or "✅ Accept"
        acceptBtn.TextColor3 = Color3.fromRGB(20, 20, 25)
        acceptBtn.Font = Enum.Font.GothamBold
        acceptBtn.TextSize = 15
        acceptBtn.ZIndex = 4
        acceptBtn.Parent = btnContainer

        local acceptCorner = Instance.new("UICorner")
        acceptCorner.CornerRadius = UDim.new(0, 8)
        acceptCorner.Parent = acceptBtn

        acceptBtn.MouseEnter:Connect(function()
            acceptBtn.BackgroundColor3 = Color3.fromRGB(255, 215, 80)
        end)
        acceptBtn.MouseLeave:Connect(function()
            acceptBtn.BackgroundColor3 = Color3.fromRGB(255, 200, 50)
        end)

        popup.BackgroundTransparency = 0.3
        TweenService:Create(popup, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
            BackgroundTransparency = 0
        }):Play()

        overlay.BackgroundTransparency = 0.8
        TweenService:Create(overlay, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
            BackgroundTransparency = 0.6
        }):Play()

        acceptBtn.MouseButton1Click:Connect(function()
            if onAccept then onAccept() end
            TweenService:Create(blur, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
                Size = 0
            }):Play()
            TweenService:Create(overlay, TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
                BackgroundTransparency = 1
            }):Play()
            TweenService:Create(popup, TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
                BackgroundTransparency = 1
            }):Play()
            task.wait(0.3)
            popupGui:Destroy()
            blur:Destroy()
        end)

        declineBtn.MouseButton1Click:Connect(function()
            if onDecline then onDecline() end
            TweenService:Create(blur, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
                Size = 0
            }):Play()
            TweenService:Create(overlay, TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
                BackgroundTransparency = 1
            }):Play()
            TweenService:Create(popup, TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
                BackgroundTransparency = 1
            }):Play()
            task.wait(0.3)
            popupGui:Destroy()
            blur:Destroy()
        end)

        return {
            Accept = acceptBtn,
            Decline = declineBtn,
            Popup = popup,
            Overlay = overlay,
            Gui = popupGui
        }
    end

    -- ============================================
    -- Anti-AFK
    -- ============================================

    LocalPlayer.Idled:Connect(function()
        if playerState.AntiAFK then
            VirtualUser:CaptureController()
            VirtualUser:ClickButton2(Vector2.new())
        end
    end)

    -- ============================================
    -- Freeze / Unfreeze
    -- ============================================

    local function toggleFreeze(state)
        local char = LocalPlayer.Character
        if not char then return end
        local root = char:WaitForChild("HumanoidRootPart")
        playerState.Frozen = state

        if state then
            local bg = Instance.new("BodyGyro", root)
            bg.Name = "AquaFreezeBG"
            bg.MaxTorque = Vector3.new(9e9, 9e9, 9e9)
            bg.CFrame = root.CFrame

            local bv = Instance.new("BodyVelocity", root)
            bv.Name = "AquaFreezeBV"
            bv.MaxForce = Vector3.new(9e9, 9e9, 9e9)
            bv.Velocity = Vector3.zero
        else
            local bg = root:FindFirstChild("AquaFreezeBG")
            if bg then bg:Destroy() end
            local bv = root:FindFirstChild("AquaFreezeBV")
            if bv then bv:Destroy() end
        end
    end

    -- ============================================
    -- Noclip
    -- ============================================

    RunService.Stepped:Connect(function()
        if playerState.Noclip and LocalPlayer.Character then
            for _, part in ipairs(LocalPlayer.Character:GetDescendants()) do
                if part:IsA("BasePart") then
                    part.CanCollide = false
                end
            end
        end
    end)

    -- ============================================
    -- Fly Logic
    -- ============================================

    local function startFly()
        local char = LocalPlayer.Character
        if not char then return end
        local root = char:WaitForChild("HumanoidRootPart")
        local humanoid = char:WaitForChild("Humanoid")

        local gyro = Instance.new("BodyGyro", root)
        gyro.P = 90000
        gyro.MaxTorque = Vector3.new(9e9, 9e9, 9e9)

        local velocity = Instance.new("BodyVelocity", root)
        velocity.MaxForce = Vector3.new(9e9, 9e9, 9e9)

        if playerState.UsePlatformStand then
            humanoid.PlatformStand = true
        end

        task.spawn(function()
            while playerState.Flying do
                local cam = workspace.CurrentCamera
                local cf = cam.CFrame
                gyro.CFrame = cf
                velocity.Velocity = Vector3.zero

                local speedMulti = UserInputService:IsKeyDown(keybinds.Speed4x) and 4
                                   or UserInputService:IsKeyDown(keybinds.Speed2x) and 2
                                   or 1

                local speed = playerState.FlySpeed * speedMulti

                if UserInputService:IsKeyDown(keybinds.Forward) then
                    velocity.Velocity += speed * cf.LookVector
                end
                if UserInputService:IsKeyDown(keybinds.Backward) then
                    velocity.Velocity -= speed * cf.LookVector
                end
                if UserInputService:IsKeyDown(keybinds.Left) then
                    velocity.Velocity -= speed * cf.RightVector
                end
                if UserInputService:IsKeyDown(keybinds.Right) then
                    velocity.Velocity += speed * cf.RightVector
                end
                if UserInputService:IsKeyDown(keybinds.Up) then
                    velocity.Velocity += speed * Vector3.new(0, 1, 0)
                end
                if UserInputService:IsKeyDown(keybinds.Down) then
                    velocity.Velocity -= speed * Vector3.new(0, 1, 0)
                end

                task.wait()
            end

            gyro:Destroy()
            velocity:Destroy()
            if playerState.UsePlatformStand then
                humanoid.PlatformStand = false
            end
        end)
    end

    -- ============================================
    -- Auto Rebirth
    -- ============================================

    local function startAutoRebirth()
        task.spawn(function()
            while playerState.AutoRebirth do
                pcall(function()
                    local rebirthRemote = ReplicatedStorage:FindFirstChild("Remotes")
                    if rebirthRemote then
                        local rebirth = rebirthRemote:FindFirstChild("Rebirth")
                        if rebirth then
                            rebirth:FireServer()
                        end
                    end
                    task.wait(1)
                end)
                task.wait()
            end
        end)
    end

    -- ============================================
    -- Farm Last Zone (Wins Farm)
    -- ============================================

    local farmLastZoneRunning = false
    local lastZonePosition = CFrame.new(-14001, 765, 3067)
    local teleportDistance = 250
    local heartbeatConnection = nil

    local function startFarmLastZone()
        if farmLastZoneRunning then return end
        farmLastZoneRunning = true

        task.spawn(function()
            while playerState.FarmLastZone do
                pcall(function()
                    local char = LocalPlayer.Character
                    if not char then return end

                    local root = char:FindFirstChild("HumanoidRootPart")
                    if not root then return end

                    for _, part in ipairs(char:GetDescendants()) do
                        if part:IsA("BasePart") and part.CanCollide then
                            part.CanCollide = false
                        end
                    end

                    local distance = (lastZonePosition.Position - root.Position).Magnitude

                    if distance < 0.5 then
                        root.CFrame = lastZonePosition
                        farmLastZoneRunning = false
                        return
                    end

                    root.AssemblyLinearVelocity = Vector3.zero

                    local function teleportLoop(deltaTime)
                        if not playerState.FarmLastZone then
                            if heartbeatConnection then
                                heartbeatConnection:Disconnect()
                                heartbeatConnection = nil
                            end
                            farmLastZoneRunning = false
                            return
                        end

                        local char = LocalPlayer.Character
                        if not char then
                            if heartbeatConnection then
                                heartbeatConnection:Disconnect()
                                heartbeatConnection = nil
                            end
                            farmLastZoneRunning = false
                            return
                        end

                        local root = char:FindFirstChild("HumanoidRootPart")
                        if not root then
                            if heartbeatConnection then
                                heartbeatConnection:Disconnect()
                                heartbeatConnection = nil
                            end
                            farmLastZoneRunning = false
                            return
                        end

                        local currentDist = (lastZonePosition.Position - root.Position).Magnitude

                        if currentDist < 0.5 then
                            root.CFrame = lastZonePosition
                            if heartbeatConnection then
                                heartbeatConnection:Disconnect()
                                heartbeatConnection = nil
                            end
                            farmLastZoneRunning = false
                            return
                        end

                        root.AssemblyLinearVelocity = Vector3.zero
                        local currentCF = root.CFrame
                        root.CFrame = currentCF:Lerp(lastZonePosition, math.min(teleportDistance * deltaTime / currentDist, 1))
                    end

                    heartbeatConnection = RunService.Heartbeat:Connect(teleportLoop)
                end)
                task.wait(0.1)
            end
            farmLastZoneRunning = false
        end)
    end

    -- ============================================
    -- Create Tabs
    -- ============================================

    local mainTab = hub:Tab("Main", "🏠")
    local passTab = hub:Tab("Gamepasses", "⭐")
    local supportTab = hub:Tab("Support", "❤️")

    -- ============================================
    -- Main Tab
    -- ============================================

    mainTab:Section("Movement Controls")

    local jumpPowerValues = {50, 75, 100, 125, 150, 175, 200, 250, 300, 350, 400, 450, 500}

    mainTab:Slider("Jump Power", jumpPowerValues, 1)

    mainTab:Toggle(
        "Freeze Position [ON]",
        "Freeze Position [OFF]",
        function()
            toggleFreeze(true)
            return true
        end,
        function()
            toggleFreeze(false)
        end
    )

    mainTab:Button("Toggle Freeze (Keybind: L)", function()
        playerState.Frozen = not playerState.Frozen
        toggleFreeze(playerState.Frozen)
        hub:Notify("Freeze", playerState.Frozen and "Frozen!" or "Unfrozen!")
    end)

    mainTab:Toggle(
        "Noclip [ON]",
        "Noclip [OFF]",
        function()
            playerState.Noclip = true
            return true
        end,
        function()
            playerState.Noclip = false
        end
    )

    mainTab:Divider()
    mainTab:Section("Fly Settings")

    local flyToggleState = false
    mainTab:Toggle(
        "Fly Enabled [ON]",
        "Fly Enabled [OFF]",
        function()
            playerState.Flying = true
            flyToggleState = true
            startFly()
            return true
        end,
        function()
            playerState.Flying = false
            flyToggleState = false
        end
    )

    mainTab:Button("Toggle Fly (Keybind: F)", function()
        flyToggleState = not flyToggleState
        playerState.Flying = flyToggleState
        if flyToggleState then
            startFly()
            hub:Notify("Fly", "Fly enabled!")
        else
            hub:Notify("Fly", "Fly disabled!")
        end
    end)

    local flySpeedValues = {10, 25, 50, 75, 100, 150, 200, 300, 400, 500}
    mainTab:Slider("Fly Speed", flySpeedValues, 3)

    mainTab:Divider()
    mainTab:Section("Auto Features")

    -- Auto Rebirth Toggle
    mainTab:Toggle(
        "Auto Rebirth [ON]",
        "Auto Rebirth [OFF]",
        function()
            playerState.AutoRebirth = true
            startAutoRebirth()
            hub:Notify("Auto Rebirth", "Started!")
            return true
        end,
        function()
            playerState.AutoRebirth = false
            hub:Notify("Auto Rebirth", "Stopped!")
        end
    )

    -- Farm Last Zone Toggle with Warning Popup
    local farmLastZoneBtn = nil
    local farmLastZoneEnabled = false

    local function createFarmLastZoneToggle()
        farmLastZoneBtn = mainTab:Toggle(
            "Farm Last Zone [ON]",
            "Farm Last Zone [OFF]",
            function()
                createPopup(
                    "⚠️ Warning",
                    "Farm Last Zone may cause you to get kicked from the game.\nProceed with caution.",
                    "✅ Accept (Enable)",
                    "❌ Decline (Disable)",
                    function()
                        playerState.FarmLastZone = true
                        farmLastZoneEnabled = true
                        startFarmLastZone()
                        hub:Notify("Farm Last Zone", "Enabled! (Use at your own risk)")
                        if farmLastZoneBtn and farmLastZoneBtn.SetState then
                            farmLastZoneBtn:SetState(true)
                        end
                    end,
                    function()
                        playerState.FarmLastZone = false
                        farmLastZoneEnabled = false
                        hub:Notify("Farm Last Zone", "Disabled!")
                        if farmLastZoneBtn and farmLastZoneBtn.SetState then
                            farmLastZoneBtn:SetState(false)
                        end
                    end
                )
                return false
            end,
            function()
                playerState.FarmLastZone = false
                farmLastZoneEnabled = false
                if heartbeatConnection then
                    heartbeatConnection:Disconnect()
                    heartbeatConnection = nil
                end
                farmLastZoneRunning = false
                hub:Notify("Farm Last Zone", "Stopped!")
            end
        )
    end

    createFarmLastZoneToggle()

    -- ============================================
    -- Gamepasses Tab
    -- ============================================

    passTab:Section("Gamepass Bypasses")

    passTab:Button("Unlock Diamond Treadmill", function()
        local clientState = require(ReplicatedStorage:WaitForChild("ClientState"))
        local oldGet = clientState.Get
        clientState.Get = function(...)
            local state = oldGet(...)
            state.DiamondTreadmillActive = true
            return state
        end
        hub:Notify("Success", "Diamond Treadmill Activated!")
    end)

    passTab:Button("Unlock Gold Treadmill", function()
        local clientState = require(ReplicatedStorage:WaitForChild("ClientState"))
        local oldGet = clientState.Get
        clientState.Get = function(...)
            local state = oldGet(...)
            state.GoldTreadmillActive = true
            return state
        end
        hub:Notify("Success", "Gold Treadmill Activated!")
    end)

    passTab:Divider()
    passTab:Section("Rewards")

    passTab:Button("Claim Group Reward", function()
        local remotes = ReplicatedStorage:FindFirstChild("Remotes")
        if remotes then
            local claim = remotes:FindFirstChild("ClaimGift")
            if claim then
                claim:FireServer()
                hub:Notify("Claimed", "Group reward remote fired!")
            else
                hub:Notify("Error", "ClaimGift remote not found!")
            end
        else
            hub:Notify("Error", "Remotes not found!")
        end
    end)

    -- ============================================
    -- Support Tab
    -- ============================================

    supportTab:Section("Community & Support")

    supportTab:Button("Copy Discord Invite", function()
        hub:Copy("https://discord.gg/2WesZEXwrH")
        hub:Notify("Copied!", "Discord link copied to clipboard!")
    end)

    supportTab:Label("Join to report bugs or request features!")

    -- ============================================
    -- Startup Notifications
    -- ============================================

    task.wait(1)

    hub:Notify("Support Needed!", "Join our Discord for updates and help: discord.gg/2WesZEXwrH", 10)
    hub:Notify("System Note", "Anti-AFK is auto-toggled. Enjoy 24/7 farming!", 5)
    hub:Notify("Keyboard Escape", "Hub loaded successfully!", 3)

    -- ============================================
    -- Return state for external access
    -- ============================================

    return {
        playerState = playerState,
        keybinds = keybinds,
        toggleFreeze = toggleFreeze,
        startFly = startFly,
        startAutoRebirth = startAutoRebirth,
        startFarmLastZone = startFarmLastZone,
        createPopup = createPopup
    }
end
