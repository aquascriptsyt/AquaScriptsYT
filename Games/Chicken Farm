return function(hub)
    local Players = game:GetService("Players")
    local ReplicatedStorage = game:GetService("ReplicatedStorage")
    local UserInputService = game:GetService("UserInputService")
    local LocalPlayer = Players.LocalPlayer
    
    local EggCollectorEnabled = false
    local LuckyBlockCollectorEnabled = false
    local EggsFolder = workspace:WaitForChild("Eggs")
    
    task.spawn(function()
        while task.wait(0.1) do
            if not EggCollectorEnabled and not LuckyBlockCollectorEnabled then
                continue
            end
            
            local character = LocalPlayer.Character
            if not character then
                continue
            end
            
            local root = character:FindFirstChild("HumanoidRootPart")
            if not root then
                continue
            end
            
            local rootCF = root.CFrame
            
            for _, object in ipairs(EggsFolder:GetChildren()) do
                if object:IsA("Model") then
                    if EggCollectorEnabled and object:GetAttribute("Tier") then
                        object:PivotTo(rootCF)
                    elseif LuckyBlockCollectorEnabled and object:GetAttribute("LuckyBlock") then
                        object:PivotTo(rootCF)
                    end
                end
            end
        end
    end)
    
    local RemoteFunction = ReplicatedStorage:WaitForChild("Paper"):WaitForChild("Remotes"):WaitForChild("__remotefunction")
    
    local function FireRemote(...)
        local args = {...}
        local ok, result = pcall(function()
            return RemoteFunction:InvokeServer(unpack(args))
        end)
        if not ok then
            warn("[ChickenController] Remote call failed: " .. tostring(result))
        end
        return ok, result
    end
    
    local economyTab = hub:Tab("Economy", "💰")
    local eggsTab = hub:Tab("Eggs", "🥚")
    local chickensTab = hub:Tab("Chickens", "🐔")
    local miscTab = hub:Tab("Misc", "🔗")
    
    economyTab:Section("Economy Controls")
    
    economyTab:Button("Collect Cash", function()
        FireRemote("Collect Cash")
        hub:Notify("Chicken Controller", "Cash collected!")
    end)
    
    economyTab:Toggle(
        "Auto Collect Cash [ON]",
        "Auto Collect Cash [OFF]",
        function()
            task.spawn(function()
                while true do
                    FireRemote("Collect Cash")
                    task.wait(1)
                end
            end)
            hub:Notify("Chicken Controller", "Auto collect cash started!")
            return true
        end,
        function()
            hub:Notify("Chicken Controller", "Auto collect cash stopped.")
        end
    )
    
    economyTab:Divider()
    
    economyTab:Button("Upgrade Process Level", function()
        FireRemote("Upgrade Process Level")
        hub:Notify("Chicken Controller", "Upgraded!")
    end)
    
    economyTab:Toggle(
        "Auto Upgrade [ON]",
        "Auto Upgrade [OFF]",
        function()
            task.spawn(function()
                while true do
                    FireRemote("Upgrade Process Level")
                    task.wait(2)
                end
            end)
            hub:Notify("Chicken Controller", "Auto upgrade started!")
            return true
        end,
        function()
            hub:Notify("Chicken Controller", "Auto upgrade stopped.")
        end
    )
    
    eggsTab:Section("Egg Controls")
    
    eggsTab:Button("Deposit Eggs", function()
        FireRemote("Deposit Eggs")
        hub:Notify("Chicken Controller", "Eggs deposited!")
    end)
    
    eggsTab:Toggle(
        "Auto Deposit Eggs [ON]",
        "Auto Deposit Eggs [OFF]",
        function()
            task.spawn(function()
                while true do
                    FireRemote("Deposit Eggs")
                    task.wait(1)
                end
            end)
            hub:Notify("Chicken Controller", "Auto deposit started!")
            return true
        end,
        function()
            hub:Notify("Chicken Controller", "Auto deposit stopped.")
        end
    )
    
    eggsTab:Divider()
    
    eggsTab:Toggle(
        "Egg Collector [ON]",
        "Egg Collector [OFF]",
        function()
            EggCollectorEnabled = true
            hub:Notify("Chicken Controller", "Egg collector enabled!")
            return true
        end,
        function()
            EggCollectorEnabled = false
            hub:Notify("Chicken Controller", "Egg collector disabled.")
        end
    )
    
    eggsTab:Toggle(
        "Auto Collect Lucky Blocks [ON]",
        "Auto Collect Lucky Blocks [OFF]",
        function()
            LuckyBlockCollectorEnabled = true
            hub:Notify("Chicken Controller", "Lucky block collector enabled!")
            return true
        end,
        function()
            LuckyBlockCollectorEnabled = false
            hub:Notify("Chicken Controller", "Lucky block collector disabled.")
        end
    )
    
    chickensTab:Section("Chicken Controls")
    
    local chickenAmount = chickensTab:Dropdown("Select Amount", {1, 5, 25, 100})
    
    chickensTab:Button("Buy Chickens", function()
        local amt = chickenAmount()
        if not amt then
            hub:Notify("Chicken Controller", "Select an amount first!")
            return
        end
        FireRemote("Buy Chickens", amt)
        hub:Notify("Chicken Controller", "Bought " .. tostring(amt) .. " chickens!")
    end)
    
    chickensTab:Toggle(
        "Auto Buy Chickens [ON]",
        "Auto Buy Chickens [OFF]",
        function()
            local amt = chickenAmount()
            if not amt then
                hub:Notify("Chicken Controller", "Select an amount first!")
                return false
            end
            task.spawn(function()
                while true do
                    FireRemote("Buy Chickens", amt)
                    task.wait(1.5)
                end
            end)
            hub:Notify("Chicken Controller", "Auto buy started!")
            return true
        end,
        function()
            hub:Notify("Chicken Controller", "Auto buy stopped.")
        end
    )
    
    chickensTab:Divider()
    
    chickensTab:Button("Merge Chickens", function()
        FireRemote("Merge Chickens")
        hub:Notify("Chicken Controller", "Merged!")
    end)
    
    chickensTab:Toggle(
        "Auto Merge [ON]",
        "Auto Merge [OFF]",
        function()
            task.spawn(function()
                while true do
                    FireRemote("Merge Chickens")
                    task.wait(1.5)
                end
            end)
            hub:Notify("Chicken Controller", "Auto merge started!")
            return true
        end,
        function()
            hub:Notify("Chicken Controller", "Auto merge stopped.")
        end
    )
    
    miscTab:Section("Links")
    miscTab:Button("Copy Discord Invite", function()
        hub:Copy("https://discord.gg/nQr2ZFE6Ae")
        hub:Notify("Chicken Controller", "Discord link copied!")
    end)
    
    miscTab:Section("Info")
    miscTab:Label("Chicken Controller v1.0", Color3.fromRGB(150, 150, 150))
    miscTab:Label("AquaScripts Hub", Color3.fromRGB(100, 180, 255))
    
    task.wait(1)
    hub:Notify("Chicken Controller", "Loaded successfully!", 3)
end
